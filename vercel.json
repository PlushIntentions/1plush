{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/login",      "dest": "/admin-login.html"           },
    { "src": "/admin",      "dest": "/admin-dashboard.html"       },
    { "src": "/tech",       "dest": "/technician-portal.html"     },
    { "src": "/onboarding", "dest": "/technician-onboarding.html" },
    { "src": "/reset",      "dest": "/reset-password.html"        },
    { "src": "/verify",     "dest": "/email-verify.html"          },
    { "src": "/(.*)",       "dest": "/$1"                         }
  ]
}
